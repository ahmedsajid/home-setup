# {{ ansible_managed }}
# Jellyfin is the only public exception (private ranges + optional [share] allowed_ip).
# HTTPS catchall: external clients 403 (private-networks), internal clients 404.
http:
  routers:
    jellyfin:
      rule: "Host(`jellyfin.{{ do_domain }}`)"
      entryPoints:
        - https
      middlewares:
        - jellyfin-ipallowlist
      service: jellyfin
      tls: {}

    catchall-https:
      rule: "HostRegexp(`{host:.+}`)"
      entryPoints:
        - https
      priority: 1
      middlewares:
        - private-networks
        - catchall-not-found
      service: api@internal
      tls: {}

  middlewares:
    private-networks:
      ipAllowList:
        sourceRange:
{% for cidr in traefik_private_ranges %}
          - "{{ cidr }}"
{% endfor %}
    jellyfin-ipallowlist:
      ipAllowList:
        sourceRange:
{% for cidr in traefik_private_ranges %}
          - "{{ cidr }}"
{% endfor %}
{% if share_allowed_ip | default('', true) | trim | length > 0 %}
          - "{{ share_allowed_ip | trim }}/32"
{% endif %}
    catchall-not-found:
      replacePath:
        path: /api/__catchall_not_found__

  services:
    jellyfin:
      loadBalancer:
        servers:
          - url: "http://host.docker.internal:8096"
