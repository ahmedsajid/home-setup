# {{ ansible_managed }}
# Jellyfin is the only public exception (private ranges + optional [share] allowed_ip).
http:
  routers:
    jellyfin:
      rule: "Host(`jellyfin.{{ do_domain }}`)"
      entryPoints:
        - https
      middlewares:
        - jellyfin-ipallowlist
      service: jellyfin
      tls: {}

  middlewares:
    jellyfin-ipallowlist:
      ipAllowList:
        sourceRange:
{% for cidr in traefik_private_ranges %}
          - "{{ cidr }}"
{% endfor %}
{% if share_allowed_ip | default('', true) | trim | length > 0 %}
          - "{{ share_allowed_ip | trim }}/32"
{% endif %}

  services:
    jellyfin:
      loadBalancer:
        servers:
          - url: "http://host.docker.internal:8096"
