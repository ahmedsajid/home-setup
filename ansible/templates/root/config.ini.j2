# {{ ansible_managed }}

[defaults]

# callbacks
callback_enabled = healthchecks, profile_tasks, ara

[callback_healthchecks]
uuid = {{ healthchecks_uuid | default('') }}

[digitalocean]
host = {{ digitalocean_host | default('*') }}
domain = {{ digitalocean_domain | default('') }}
token = {{ digitalocean_token | default('') }}

[share]
# Only this IP may reach jellyfin.{{ digitalocean_domain | default('yourdomain') }} via Traefik; leave empty to block remote access
allowed_ip = {{ share_allowed_ip | default('') }}
